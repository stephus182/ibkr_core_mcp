# ibkr_core_mcp — environment variables
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (required if using ClaudeToolkit or MCP server)
ANTHROPIC_API_KEY=sk-ant-...

# IBKR Client Portal Gateway URL (default shown; change port if using a custom one)
IBKR_GATEWAY_URL=https://localhost:5055

# SQLite store path for trade history, alerts, and position snapshots
IBKR_SQLITE_PATH=~/.ibkr_core/store.db

# ── Google Drive cache (required for fetch_market_data caching) ───────────────

# Root Drive folder used for claudia.db sync and as parent for the cache subfolder.
# Get the ID from the folder's URL: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Optional: dedicated folder for claudia.db.
# Leave EMPTY → GDriveSync auto-creates a 'db/' subfolder inside GOOGLE_DRIVE_FOLDER_ID
# on first sync (recommended — keeps the DB separate from context files).
GDRIVE_DB_FOLDER_ID=

# Optional: dedicated folder for OHLCV Parquet files.
# Leave EMPTY → GDriveCache auto-creates a 'market_data/' subfolder inside
# GOOGLE_DRIVE_FOLDER_ID on first use (recommended — keeps cache files separate).
# Set explicitly to point to a pre-existing folder.
GDRIVE_CACHE_FOLDER_ID=

# Paths to your OAuth2 credentials (from Google Cloud Console)
GDRIVE_TOKEN_FILE=~/.ibkr_core/gdrive_token.json
GDRIVE_CREDENTIALS_FILE=~/.ibkr_core/gdrive_credentials.json

# ── Optional — IBKR Flex Web Service (full trade history sync) ────────────────

# Flex Web Service token (from IBKR Account Management → Reports → Flex Queries)
IBKR_FLEX_TOKEN=

# Flex query ID created in IBKR Account Management
IBKR_FLEX_QUERY_ID=

# ── Firecrawl web scraper (optional — enables firecrawl_search and firecrawl_crawl tools) ──

FIRECRAWL_API_KEY=

# Override the auto-created web_docs/ Drive subfolder (optional)
GDRIVE_WEB_DOCS_FOLDER_ID=
